@model IEnumerable<booksXrelaysSomaShare.Models.Review>

@{
    ViewData["Title"] = "Reviews";
}

<h1>Reviews</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Review</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No reviews found.
    </div>
}

<table class="table">
    <thead>
        <tr>
            <th>Transaction ID</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.TransactionId</td>

            <td>
                @item.Rating / 5
            </td>

            <td>
                @item.Comment
            </td>

            <td>
                <a asp-action="Edit" asp-route-id="@item.ReviewId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ReviewId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ReviewId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>