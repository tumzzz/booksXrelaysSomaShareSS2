@model IEnumerable<booksXrelaysSomaShare.Models.Textbook>

@{
    ViewData["Title"] = "Index";
}

<h1> SomaShare Textbooks List</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="form-group mb-2">
        <input type="text" name="search" class="form-control"
        placeholder="Search by title, author, ISBN or module" />
    </div>

    <button type="submit" class="btn btn-primary">Search</button>
    <a asp-action="Index" class="btn btn-secondary">Clear</a>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No textbooks found.
    </div>
}

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Description</th>
            <th>ISBN</th>
            <th>Module</th>
            <th>Price</th>
            <th>Listing Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.Description</td>
                <td>@item.ISBN</td>
                <td>@item.Module</td>
                <td>@item.Price</td>
                <td>@item.ListingDate</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.TextBookID">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.TextBookID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
